# ===========================
# Environment
# ===========================
.env

# ===========================
# Virtual Environments
# ===========================
venv/
.venv/
env/

# ===========================
# Python Cache
# ===========================
__pycache__/
*.py[cod]
.pytest_cache/

# ===========================
# TensorFlow Model Files
# ===========================
*.pb
*.pbtxt

# ===========================
# Ignore Data Folder
# ===========================
data/

# ===========================
# Ignore Images Everywhere
# ===========================
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.svg

# ===========================
# Allow Dataset Images
# ===========================
!dataset/
!dataset/**
!dataset/**/*.jpg
!dataset/**/*.jpeg
!dataset/**/*.png
!dataset/**/*.gif
!dataset/**/*.bmp
!dataset/**/*.tif
!dataset/**/*.tiff
!dataset/**/*.webp
!dataset/**/*.svg

# ===========================
# Allow Output Screenshots
# ===========================
!output_images/
!output_images/**
!output_images/**/*.jpg
!output_images/**/*.jpeg
!output_images/**/*.png
!output_images/**/*.gif
!output_images/**/*.bmp
!output_images/**/*.tif
!output_images/**/*.tiff
!output_images/**/*.webp
!output_images/**/*.svg

# ===========================
# Ignore Copied Files
# ===========================
*- Copy.*

# ===========================
# IDE Files
# ===========================
.vscode/
.idea/

# ===========================
# Logs
# ===========================
*.log

# ===========================
# Git Attributes
# ===========================
**/.gitattributes