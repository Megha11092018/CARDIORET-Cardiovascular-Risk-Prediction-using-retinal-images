# Environment
.env

# Virtual environments
venv/
.venv/
env/

# Python cache
__pycache__/
*.pyc
.pytest_cache/

# TensorFlow model files
*.pb
*.pbtxt

# Ignore data folder (but keep dataset folder)
data/

# Ignore images everywhere
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.svg

# Allow images inside dataset folder
!dataset/
!dataset/**
!dataset/**/*.jpg
!dataset/**/*.jpeg
!dataset/**/*.png
!dataset/**/*.gif
!dataset/**/*.bmp
!dataset/**/*.tif
!dataset/**/*.tiff
!dataset/**/*.webp
!dataset/**/*.svg

# Ignore copied files
*- Copy.*

# IDE files
.vscode/
.idea/

# Logs
*.log

# Git attributes
**/.gitattributes